  "text_words": [
    {
      "id": "t1",
      "text": "እግዚአብሔር ስሙ ኤልሐው ኤልዐትና ንሑር አሐው ዐቢይ ይሁኑ።",
      "position": "top center, title line 1",
      "color": "black"
    },
    {
      "id": "t2",
      "text": "አስቀድሞ አማልክት ንጉሥ ለኢየሩሳሌም",
      "position": "top center, title line 2",
      "color": "black"
    },
    {
      "id": "t3",
      "text": "ዕፅድ",
      "position": "below top-left diagram",
      "color": "red"
    },
    {
      "id": "t4",
      "text": "ጸናጽል",
      "position": "below top-right diagram",
      "color": "red"
    },
    {
      "id": "t5",
      "text": "ያንሴት",
      "position": "below bottom-left diagram",
      "color": "red"
    },
    {
      "id": "t6",
      "text": "ለሐዋርያት",
      "position": "below bottom-right diagram",
      "color": "red"
    },
    {
      "id": "t7",
      "text": "እንዲሁም እንደ ሌሊቱ ስሙን ፍጻሜውን አልፎ አልፎ ሆዳይ ሆዳይ። ሃይማኖት እና ዘነጋ ህዝቦች ለእግዚአብሔር ሲሉት ያህል። ከባዶ እግዚአብሔር ይባርክሃል አቤት እግዚአብሔር ይጠብቅሃል አቤት ከሆነ እግዚአብሔር ያበራልሃል።",
      "position": "bottom paragraph line 1-2",
      "color": "black"
    },
    {
      "id": "t8",
      "text": "ወንድማችሁ ኢየሱስ መስቀል አስቀድሞ ሆኖ አልተሰቀለም።",
      "position": "bottom paragraph, inline",
      "color": "black"
    },
    {
      "id": "t9",
      "text": "ቀሪውንም ይጻፋል ውህብሎስ አልተጻፈም። አልተጽፈምም። ለአብ ከእግዚአብሔር ጋር ይኖራል። ከእግዚአብሔር ጋር ይኖራል።",
      "position": "bottom paragraph lines 2-4",
      "color": "black"
    },
    {
      "id": "t10",
      "text": "አሕዲብ እንደ ተባለ አንድ ስሙ ሃይማኖት እንደ ሆነ አንድ ስሙ እግዚአብሔር ይባርካል ባልናል። አንድንም አይደለም ያህል አልተፃፈም ስሙ።",
      "position": "bottom paragraph lines 4-6",
      "color": "black"
    },
    {
      "id": "t11",
      "text": "አሕዲብ ብለው ያህል ስሙ እንደ ተረት ይሆናል አላህ።",
      "position": "bottom paragraph inline",
      "color": "black"
    },
    {
      "id": "t12",
      "text": "እንደ ተረት ይሆናል ስሙ እንደ ተረት ይሆናል ስሙ አላህ።",
      "position": "bottom paragraph",
      "color": "black"
    },
    {
      "id": "t13",
      "text": "ያህል ስሙን ሃይማኖት አንድ ስሙ እንደ ተረት ይሆናል።",
      "position": "bottom paragraph",
      "color": "black"
    },
    {
      "id": "t14",
      "text": "አሕዲብ እንደ ተረት ይሆናል ስሙ። እንደ ተረት ሆኖ ይሆናል ስሙ አላህ።",
      "position": "bottom paragraph",
