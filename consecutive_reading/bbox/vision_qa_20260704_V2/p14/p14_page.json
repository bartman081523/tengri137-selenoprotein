  "text_words": [
    {
      "text": "የሚያስፈልግህ ብዙ የምኞ ንግሥት ናበው የእግዚአብሔር ገዙ ሙሉ ደግሞ በልብ ይከብራል። ወይምስ ገን ያረገ ሓይ ጽን ነገስስት። አልጋይ አርገ ቅኔስ ሀነዎች በኖበል አድራስ ያልፍአና። ሀንው አግንቱስት ነግሥት ቀለስ ለአድረስ ስንያም ሃይ",
      "bbox": [
        175,
        120,
        685,
        220
      ],
      "color": "black",
      "lang": "gez"
    },
    {
      "text": "ምእምናህ እህሉ አለ የክህዎሆ ሐይ ሕብረተስብ ነግስትንምስት ነኝስ ገዙ በልብ ሓለይን በኖብላ ደግሞ ቀለስ ለይን። ለገዛህዎራሉ ናን ቀለስም ሰነዎች ናስ አስቀዳሚያ ገን በልብ ይከብራል። ለአድረስ ሁሉ በልብናት የአድናብናት",
      "bbox": [
        180,
        490,
        690,
        590
      ],
      "color": "black",
      "lang": "gez"
    },
    {
      "text": "ለ ነ ያድላይ ሓለይ ነግስት ነኝስ ሰነዎች ሓይ ነግስት ነኝስብ ነግስት ለይናብ። ማድላይ ሓለይ ነግስት ወይምስ በልብ ያርገማትም። ወይምስ ሓለይ ቅኔስ ነግስት። ሰንያም ቅኔስ ነግስት ወይምስ ያስማማር ሰነዎች ለአድረስ ሀንው ሃይ ምንምን። 1፩",
      "bbox": [
        165,
        620,
        690,
        780
      ],
      "color": "black",
      "lang": "gez"
    },
    {
      "text": "ሰነዎች ሓለይ ነኝስ ለይናብ። ሓይንምስብ በልብ ሐለይ ቀለስ። 1፩ 2፪ 1፩ 1፩፩ ሓለይ ሰነዎች ለይናብ። ለይናብስ ሐለይ ሰነዎች ይከብራል። 1፩ 1፩ ምንያህሎች ደላይ ሓለይ ሰነዎች",
      "bbox": [
        165,
        810,
        690,
        920
      ],
      "color": "black",
      "lang": "gez"
    }
  ],
