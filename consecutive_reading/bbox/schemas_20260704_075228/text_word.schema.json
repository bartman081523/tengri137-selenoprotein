{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["text", "bbox"],
  "properties": {
    "text": {"type": "string"},
    "bbox": {
      "type": "array",
      "items": {"type": "integer"},
      "minItems": 4,
      "maxItems": 4,
      "description": "[left, top, width, height] in pixels"
    },
    "conf_tesseract": {"type": "number"},
    "color": {
      "type": "string",
      "enum": ["black", "dark_grey", "light_grey", "red", "blue", "orange", "green", "yellow", "other"]
    },
    "verified_by_vision": {"type": "boolean", "default": false}
  }
}
