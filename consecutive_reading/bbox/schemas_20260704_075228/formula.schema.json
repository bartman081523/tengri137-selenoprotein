{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["raw", "bbox", "symbols"],
  "properties": {
    "raw": {"type": "string", "description": "Verbatim formula text, e.g. '2^9 x 3^-1 x 5^9'"},
    "bbox": {
      "type": "array",
      "items": {"type": "integer"},
      "minItems": 4,
      "maxItems": 4
    },
    "symbols": {
      "type": "array",
      "items": {"type": "string"},
      "description": "Each token in the formula, in order (digits, operators, letters)."
    },
    "color": {"type": "string"}
  }
}
