{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["value", "bbox"],
  "properties": {
    "value": {"type": "string"},
    "bbox": {
      "type": "array",
      "items": {"type": "integer"},
      "minItems": 4,
      "maxItems": 4
    },
    "color": {"type": "string", "enum": ["black", "red", "blue", "orange", "green", "other"]}
  }
}
