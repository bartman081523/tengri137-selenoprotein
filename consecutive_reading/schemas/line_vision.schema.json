{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://tengri137.local/schemas/line_vision.schema.json",
  "title": "Tengri137 Line Vision (V4)",
  "description": "V4 Vision-Schema für zeilenweise Analyse: identifiziert unbekannte Glyphen, lateinische Tokens, Zahlen, Formeln, Grafiken. Pro Zeile ein Call.",
  "type": "object",
  "required": ["line_type", "glyphs", "latin_tokens"],
  "properties": {
    "line_type": {
      "type": "string",
      "enum": [
        "pure_glyph_line",
        "pure_latin_line",
        "pure_numeric_line",
        "pure_formula_line",
        "graphic_line",
        "mixed_line",
        "empty_line"
      ],
      "description": "Was dominiert diese Zeile?"
    },
    "line_description": {
      "type": "string",
      "description": "Kurze Beschreibung des Zeileninhalts (1-2 Sätze)."
    },
    "glyphs": {
      "type": "array",
      "description": "Glyph-Instanzen in dieser Zeile (jede mit eigener BBox in der Zeile).",
      "items": {
        "type": "object",
        "required": ["bbox", "visual_kind", "description"],
        "properties": {
          "bbox": {
            "type": "array",
            "description": "Bbox relativ zur Zeile (x0, y0, w, h)",
            "items": {"type": "integer", "minimum": 0},
            "minItems": 4,
            "maxItems": 4
          },
          "visual_kind": {
            "type": "string",
            "description": "Beschreibung der visuellen Familie",
            "enum": [
              "geometric_diamond",
              "geometric_diamond_with_dot",
              "geometric_circle",
              "geometric_circle_with_dot",
              "geometric_circle_with_cross",
              "geometric_filled_square",
              "geometric_bracket",
              "turkic_round_rune",
              "chinese_oracle_script",
              "chinese_seal_script",
              "face_circle_three_dots",
              "magic_cube_3x3",
              "odin_triple_horn",
              "seven_rings",
              "nine_rings",
              "math_pi",
              "math_times",
              "math_equals",
              "math_exponentiation",
              "math_paren",
              "digit",
              "punctum",
              "line",
              "unknown",
              "other"
            ]
          },
          "description": {
            "type": "string",
            "description": "Detaillierte visuelle Beschreibung"
          },
          "unicode_codepoint_candidate": {
            "type": "string",
            "description": "z.B. U+5929 für tian (heaven)"
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        }
      }
    },
    "latin_tokens": {
      "type": "array",
      "description": "Lateinische Wörter oder Wortgruppen (mit Position in der Zeile).",
      "items": {
        "type": "object",
        "required": ["text", "bbox"],
        "properties": {
          "text": {"type": "string"},
          "bbox": {
            "type": "array",
            "items": {"type": "integer", "minimum": 0},
            "minItems": 4,
            "maxItems": 4
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        }
      }
    },
    "numerics": {
      "type": "array",
      "description": "Zahlen (nicht lateinisch)",
      "items": {
        "type": "object",
        "required": ["value", "bbox"],
        "properties": {
          "value": {"type": "string"},
          "bbox": {
            "type": "array",
            "items": {"type": "integer", "minimum": 0},
            "minItems": 4,
            "maxItems": 4
          }
        }
      }
    },
    "formulas": {
      "type": "array",
      "description": "Mathematische Ausdrücke (nicht in lateinische Wörter integriert)",
      "items": {
        "type": "object",
        "required": ["raw", "bbox"],
        "properties": {
          "raw": {"type": "string"},
          "bbox": {
            "type": "array",
            "items": {"type": "integer", "minimum": 0},
            "minItems": 4,
            "maxItems": 4
          }
        }
      }
    },
    "graphics": {
      "type": "array",
      "description": "Dekorative Linien, Bögen, Rahmen",
      "items": {
        "type": "object",
        "required": ["type", "description", "bbox"],
        "properties": {
          "type": {"type": "string"},
          "description": {"type": "string"},
          "bbox": {
            "type": "array",
            "items": {"type": "integer", "minimum": 0},
            "minItems": 4,
            "maxItems": 4
          }
        }
      }
    }
  }
}
